RewriteEngine On

# Handle API requests
RewriteCond %{REQUEST_URI} ^/api/(.*)$
RewriteRule ^api/(.*)$ api/index.php [QSA,L]

# Handle conversations API
RewriteCond %{REQUEST_URI} ^/api/conversations/(.*)$
RewriteRule ^api/conversations/(.*)$ api/conversations.php [QSA,L]

# Handle conversations API without session ID
RewriteCond %{REQUEST_URI} ^/api/conversations$
RewriteRule ^api/conversations$ api/conversations.php [QSA,L]